# Shared environment variables for docker-compose and local development.
# Copy to .env and adjust values.

# Frontend (Gemini / AI Studio)
GEMINI_API_KEY=MY_GEMINI_API_KEY
APP_URL=http://localhost:3000

# Backend
DEBUG=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/predictive_maintenance
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/predictive_maintenance_test
MLFLOW_TRACKING_URI=http://localhost:5000
CORS_ORIGINS=["http://localhost:3000"]

# Postgres (docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=predictive_maintenance
